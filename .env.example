# Server
PORT=3001
# Listen address. Default 127.0.0.1 (loopback only). Use 0.0.0.0 if you need LAN access (increases exposure).
# HOST=127.0.0.1
SHELL_DEFAULT=fish

# Optional: GitHub repo used for startup update check (GET /api/app/update-check).
# Defaults: Haroon966 / Panes on branch main. Set UPDATE_CHECK_REPOSITORY=owner/repo instead of owner + repo.
# UPDATE_CHECK_REPOSITORY=Haroon966/Panes
# UPDATE_CHECK_OWNER=Haroon966
# UPDATE_CHECK_REPO=Panes
# UPDATE_CHECK_BRANCH=main
#
# In-app “Install update” (POST /api/app/install-update). Off by default — only enable on trusted/local APIs.
# Runs UPDATE_INSTALL_COMMAND via sh -c from UPDATE_INSTALL_CWD (default: server process cwd).
# Example: UPDATE_INSTALL_ALLOW=1 and UPDATE_INSTALL_COMMAND=git pull && npm install
# UPDATE_INSTALL_ALLOW=1
# UPDATE_INSTALL_COMMAND=git pull && npm install
# UPDATE_INSTALL_CWD=/path/to/clone
# Absolute path to terminalai-fish-hook.fish if the server cwd is not the repo root (e.g. packaged app).
# TERMINALAI_FISH_HOOK=/path/to/server/shellIntegration/terminalai-fish-hook.fish

# SQLite persistence (chat, layout, non-secret prefs). API keys stay in the browser.
# Default file: ~/.config/terminalai/terminalai.db
# TERMINALAI_DATA_DIR=/path/to/dir
# TERMINALAI_DB_PATH=/path/to/terminalai.db

# Optional server-side API keys (can also be set per-user in UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Local model endpoints
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234

# Groq (OpenAI-compatible). Uncomment and set GROQ_API_KEY when using Groq as your custom base URL.
# GROQ_OPENAI_BASE_URL=https://api.groq.com/openai
# GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Agent
ENABLE_AGENT=true
# Max agent steps per request (1–20). LangGraph recursion limit defaults to min(50, max(12, steps*4))
# unless AGENT_RECURSION_LIMIT is set.
AGENT_MAX_STEPS=5
# Abort the agent stream after N consecutive identical tool calls with the same arguments (loop guard). 0 or unset = disabled.
# AGENT_TOOL_REPEAT_GUARD=3
# Optional: override LangGraph recursion limit (4–80). Use when the agent stops early despite room for more tool turns.
# AGENT_RECURSION_LIMIT=25
# Sampling temperature for TerminalAI LangChain chat models (0–2). Default 0.15 for steadier tool use.
# AGENT_TEMPERATURE=0.15
# Use chat models with native tool/function calling; weak or missing tool support causes bind/stream errors (see server logs).
# Tuning: if agent steps in chat stop early, try raising AGENT_RECURSION_LIMIT; if previews look clipped, raise AGENT_TOOL_OUTPUT_STREAM_MAX; for identical-tool loops lower AGENT_TOOL_REPEAT_GUARD.

# Human approval before write_workspace_file and search_replace_workspace_file (UI Approve / Reject; /api/agent/hitl/*).
# AGENT_REQUIRE_APPROVAL_FOR_WRITES=1
# Read-only agent: omit mutating workspace tools and run_workspace_command from the graph (grep/read/fetch/web_search still available).
# AGENT_READ_ONLY=1
# Require read_workspace_file or get_workspace_file_outline on a path before mutating it this turn (replace writes, patch, delete, copy/move source). New files (write create / replace when missing) exempt.
# AGENT_ENFORCE_READ_BEFORE_WRITE=1
# Disable heuristic secret redaction in agent tool previews / errors / HITL approve messages (OpenAI/GitHub/AWS/npm patterns, PEM blocks, etc.)
# AGENT_DISABLE_SECRET_LEAK_SCAN=1
# Pending approval TTL (ms), default 900000 (15m)
# AGENT_APPROVAL_TTL_MS=900000
# Max bytes for write_workspace_file / search_replace result (default 750000)
# AGENT_MAX_WRITE_BYTES=750000
# Truncate tool outputs embedded in the chat stream (default 1200 chars)
# AGENT_TOOL_OUTPUT_STREAM_MAX=1200
# Timeout (ms) for grep_workspace_content subprocess (min 3s, max 120s, default 45s)
# AGENT_GREP_TIMEOUT_MS=45000
# Max characters of grep output returned to the model (default 32000)
# AGENT_GREP_MAX_OUTPUT_CHARS=32000
# Disable npm/PyPI registry tools (search_npm_packages, lookup_pypi_project) for air-gapped servers
# AGENT_DISABLE_PACKAGE_REGISTRY_TOOLS=1
# Disable HTTPS fetch_url tool (allowlisted hosts only)
# AGENT_DISABLE_FETCH_URL=1
# Disable read_documentation only (chunked doc fetch; still uses fetch allowlist). fetch_url stays on unless AGENT_DISABLE_FETCH_URL=1
# AGENT_DISABLE_READ_DOCS=1
# Max characters per read_documentation chunk (1500–24000, default 6000)
# AGENT_READ_DOCS_CHUNK_CHARS=6000
# Extra hostnames allowed for fetch_url (comma-separated, exact match). Default list includes MDN, Node, PyPI, npm, GitHub raw, etc.
# AGENT_FETCH_URL_ALLOWLIST=example.com,docs.mycompany.com
# Max response body bytes for fetch_url (8000–2000000, default 400000)
# AGENT_FETCH_URL_MAX_BYTES=400000
# Timeout ms for fetch_url (3000–120000, default 20000)
# AGENT_FETCH_URL_TIMEOUT_MS=20000
# Disable DuckDuckGo instant-answer web_search tool (outbound HTTP to api.duckduckgo.com)
# AGENT_DISABLE_WEB_SEARCH=1

# Server-side shell tool (run_workspace_command). Off by default.
# AGENT_ALLOW_SHELL=1
# Require UI approval for each shell invocation (default on when shell is enabled)
# AGENT_REQUIRE_APPROVAL_FOR_SHELL=0
# Comma-separated substrings; command argv string must contain one when set (empty = no filter)
# AGENT_SHELL_ALLOWLIST=npm,git,
# AGENT_SHELL_TIMEOUT_MS=120000
# AGENT_SHELL_MAX_OUTPUT_CHARS=24000
# Force subprocess instead of the integrated browser terminal PTY (default: use PTY when tab is connected)
# AGENT_SHELL_SUBPROCESS_ONLY=1

# Optional project verify command is stored in SQLite app prefs (⚙ → Manage API Keys → Agent verify command).
# The agent tool run_project_verify_command runs it under the same shell rules as run_workspace_command.

# Workspace FTS index (search_workspace_index / rebuild_workspace_search_index). Set to 1 to disable.
# AGENT_DISABLE_WORKSPACE_FTS=1
# Soft caps while indexing (defaults: 2500 files, 65536 bytes per file)
# AGENT_WORKSPACE_FTS_MAX_FILES=2500
# AGENT_WORKSPACE_FTS_MAX_BYTES=65536
